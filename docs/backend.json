{
  "entities": {
    "client": {
      "title": "Client",
      "description": "A client of the business.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the client."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the client."
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the client."
        }
      },
      "required": ["name", "email"]
    },
    "invoice": {
      "title": "Invoice",
      "description": "An invoice for a client.",
      "type": "object",
      "properties": {
        "clientId": {
          "type": "string",
          "description": "The ID of the client this invoice belongs to."
        },
        "amount": {
          "type": "number",
          "description": "The amount of the invoice."
        },
        "status": {
          "type": "string",
          "enum": ["Paid", "Unpaid", "Overdue"],
          "description": "The status of the invoice."
        },
        "dueDate": {
          "type": "string",
          "format": "date",
          "description": "The due date of the invoice."
        }
      },
      "required": ["clientId", "amount", "status", "dueDate"]
    },
    "task": {
      "title": "Task",
      "description": "A task to be completed.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the task."
        },
        "description": {
          "type": "string",
          "description": "The description of the task."
        },
        "status": {
          "type": "string",
          "enum": ["Pending", "In Progress", "Completed"],
          "description": "The current status of the task."
        },
        "priority": {
          "type": "string",
          "enum": ["Low", "Medium", "High"],
          "description": "The priority of the task."
        },
        "dueDate": {
          "type": "string",
          "format": "date",
          "description": "The due date of the task."
        },
        "assignedTo": {
          "type": "string",
          "description": "Who the task is assigned to."
        }
      },
      "required": ["title", "status", "priority", "dueDate"]
    },
    "inventoryItem": {
      "title": "Inventory Item",
      "description": "An item in the inventory.",
      "type": "object",
      "properties": {
        "sku": {
          "type": "string",
          "description": "The SKU of the inventory item."
        },
        "name": {
          "type": "string",
          "description": "The name of the inventory item."
        },
        "category": {
            "type": "string",
            "description": "The category of the item."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of the inventory item."
        },
        "price": {
          "type": "number",
          "description": "The price of the inventory item."
        },
        "reorderLevel": {
            "type": "number",
            "description": "The minimum quantity before a restock is needed."
        }
      },
      "required": ["sku", "name", "quantity", "price"]
    },
    "businessProfile": {
      "title": "Business Profile",
      "description": "Stores the user's business profile information.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "ownerName": { "type": "string" },
        "businessEmail": { "type": "string", "format": "email" },
        "businessPhone": { "type": "string" },
        "businessAddress": { "type": "string" },
        "website": { "type": "string" },
        "taxNumber": { "type": "string" },
        "bankName": { "type": "string" },
        "accountHolder": { "type": "string" },
        "accountNumber": { "type": "string" },
        "branchCode": { "type": "string" },
        "defaultCurrency": { "type": "string" },
        "defaultTaxRate": { "type": "number" }
      }
    },
    "invoiceSettings": {
      "title": "Invoice Settings",
      "description": "Stores settings related to invoicing.",
      "type": "object",
      "properties": {
        "companyLogoUrl": { "type": "string" },
        "signatureImageUrl": { "type": "string" },
        "brandColor": { "type": "string" },
        "invoiceContactName": { "type": "string" },
        "invoiceContactEmail": { "type": "string" },
        "invoiceContactPhone": { "type": "string" },
        "invoicePrefix": { "type": "string" },
        "defaultDueDays": { "type": "number" },
        "paymentTerms": { "type": "string" },
        "footerMessage": { "type": "string" },
        "showWatermark": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": { "$ref": "#/entities/client" },
      "description": "Stores client information."
    },
    "/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/invoice" },
      "description": "Stores invoice information."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/task" },
      "description": "Stores task information."
    },
    "/inventory/{itemId}": {
      "schema": { "$ref": "#/entities/inventoryItem" },
      "description": "Stores inventory item information."
    },
    "/profiles/{userId}": {
      "schema": {
        "$ref": "#/entities/businessProfile"
      },
      "description": "Stores user-specific business profile settings."
    },
    "/profiles/{userId}/settings/invoice": {
        "schema": { "$ref": "#/entities/invoiceSettings" },
        "description": "Stores user-specific invoice settings."
    }
  }
}
